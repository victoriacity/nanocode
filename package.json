{
  "name": "codebuilder",
  "version": "0.1.0",
  "type": "module",
  "description": "Minimal web app that dispatches, views, and orchestrates Claude Code tasks",
  "scripts": {
    "dev": "node --watch server/index.js",
    "start": "node server/index.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "test": "node --test server/tests/*.test.js",
    "test:terminal-e2e": "node --test terminal/tests/e2e.test.js",
    "lint": "prettier --check .",
    "check": "npm run lint && npm run test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.41",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^11.0.0",
    "compression": "^1.8.1",
    "express": "^4.21.0",
    "node-pty": "^1.1.0-beta34",
    "ulid": "^2.3.0",
    "ws": "^8.18.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "prettier": "^3.3.0"
  }
}
